rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public write-only visitor counter with narrow schema validation.
    match /visitors/{visitId} {
      allow read: if false;
      allow create: if request.resource.data.keys().hasOnly(['lastSeen'])
                    && request.resource.data.lastSeen is timestamp;
      allow update: if request.resource.data.keys().hasOnly(['lastSeen'])
                    && request.resource.data.lastSeen is timestamp;
      allow delete: if false;
    }

    // Function-managed brute-force limiter. No client access.
    match /_adminRateLimits/{docId} {
      allow read, write: if false;
    }
  }
}
